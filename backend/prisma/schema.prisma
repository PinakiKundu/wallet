generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  blocked
  deleted
}

enum Platform {
  android
  ios
  web
  unknown
}

enum OtpPurpose {
  login
  mobile_verify
}

enum OtpStatus {
  requested
  verified
  expired
  failed
}

enum WalletOwnerType {
  user
  merchant
  system
}

enum WalletStatus {
  active
  frozen
  closed
}

enum MerchantStatus {
  pending
  active
  suspended
  closed
}

enum RiskLevel {
  low
  medium
  high
}

enum CodeStatus {
  active
  revoked
}

enum TransactionType {
  add_money
  wallet_payment
  reversal
}

enum TransactionStatus {
  initiated
  pending
  processing
  succeeded
  failed
  reversed
  expired
}

enum LedgerEntryType {
  debit
  credit
}

enum ActorType {
  user
  merchant
  system
  admin
}

enum IdempotencyStatus {
  in_progress
  completed
  failed
}

enum GatewayFlow {
  upi_intent
  upi_collect
  webhook
  status_check
}

enum GatewayDirection {
  request
  response
}

enum WebhookStatus {
  received
  processed
  duplicate
  failed
}

enum SettlementStatus {
  pending
  processing
  settled
  failed
}

model User {
  id               String         @id @default(uuid()) @db.Uuid
  mobileNumber     String         @unique @map("mobile_number") @db.VarChar(15)
  mobileVerifiedAt DateTime?      @map("mobile_verified_at") @db.Timestamptz(6)
  displayName      String?        @map("display_name") @db.VarChar(120)
  email            String?        @unique @db.VarChar(255)
  status           UserStatus     @default(active)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  devices          UserDevice[]
  refreshTokens    RefreshToken[]
  wallets          Wallet[]
  transactions     Transaction[]

  @@map("users")
}

model UserDevice {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  deviceId      String         @map("device_id") @db.VarChar(128)
  deviceName    String?        @map("device_name") @db.VarChar(120)
  platform      Platform       @default(unknown)
  appVersion    String?        @map("app_version") @db.VarChar(32)
  lastSeenAt    DateTime?      @map("last_seen_at") @db.Timestamptz(6)
  revokedAt     DateTime?      @map("revoked_at") @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User           @relation(fields: [userId], references: [id])
  refreshTokens RefreshToken[]

  @@unique([userId, deviceId])
  @@map("user_devices")
}

model RefreshToken {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  deviceRef String      @map("device_id") @db.Uuid
  tokenHash String      @map("token_hash") @db.VarChar(255)
  familyId  String      @map("family_id") @db.Uuid
  expiresAt DateTime    @map("expires_at") @db.Timestamptz(6)
  rotatedAt DateTime?   @map("rotated_at") @db.Timestamptz(6)
  revokedAt DateTime?   @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User        @relation(fields: [userId], references: [id])
  device    UserDevice  @relation(fields: [deviceRef], references: [id])

  @@index([tokenHash])
  @@index([userId, deviceRef])
  @@map("refresh_tokens")
}

model OtpChallenge {
  id            String     @id @default(uuid()) @db.Uuid
  mobileNumber  String     @map("mobile_number") @db.VarChar(15)
  purpose       OtpPurpose
  status        OtpStatus  @default(requested)
  attemptCount  Int        @default(0) @map("attempt_count")
  expiresAt     DateTime   @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  verifiedAt    DateTime?  @map("verified_at") @db.Timestamptz(6)

  @@index([mobileNumber, createdAt])
  @@map("otp_challenges")
}

model Wallet {
  id                String           @id @default(uuid()) @db.Uuid
  ownerType         WalletOwnerType  @map("owner_type")
  userId            String?          @map("user_id") @db.Uuid
  merchantId        String?          @map("merchant_id") @db.Uuid
  systemAccountCode String?          @map("system_account_code") @db.VarChar(64)
  currency          String           @default("INR") @db.Char(3)
  availableBalance  BigInt           @default(0) @map("available_balance")
  ledgerBalance     BigInt           @default(0) @map("ledger_balance")
  status            WalletStatus     @default(active)
  version           Int              @default(0)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User?            @relation(fields: [userId], references: [id])
  merchant          Merchant?        @relation(fields: [merchantId], references: [id])
  ledgerEntries     LedgerEntry[]
  sourceTxns        Transaction[]    @relation("SourceWallet")
  destinationTxns   Transaction[]    @relation("DestinationWallet")

  @@index([ownerType, userId])
  @@index([ownerType, merchantId])
  @@index([systemAccountCode])
  @@map("wallets")
}

model Merchant {
  id                String             @id @default(uuid()) @db.Uuid
  merchantCode      String             @unique @map("merchant_code") @db.VarChar(32)
  businessName      String             @map("business_name") @db.VarChar(160)
  displayName       String             @map("display_name") @db.VarChar(120)
  mobileNumber      String?            @map("mobile_number") @db.VarChar(15)
  email             String?            @db.VarChar(255)
  status            MerchantStatus     @default(pending)
  riskLevel         RiskLevel          @default(low) @map("risk_level")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  wallets           Wallet[]
  qrCodes           MerchantQrCode[]
  vendorCodes       VendorCode[]
  transactions      Transaction[]
  settlementRecords SettlementRecord[]

  @@map("merchants")
}

model MerchantQrCode {
  id         String      @id @default(uuid()) @db.Uuid
  merchantId String      @map("merchant_id") @db.Uuid
  qrPayload  String      @map("qr_payload") @db.Text
  status     CodeStatus  @default(active)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt  DateTime?   @map("revoked_at") @db.Timestamptz(6)
  merchant   Merchant    @relation(fields: [merchantId], references: [id])

  @@index([merchantId, status])
  @@map("merchant_qr_codes")
}

model VendorCode {
  id         String      @id @default(uuid()) @db.Uuid
  merchantId String      @map("merchant_id") @db.Uuid
  code       String      @unique @db.VarChar(32)
  status     CodeStatus  @default(active)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt  DateTime?   @map("revoked_at") @db.Timestamptz(6)
  merchant   Merchant    @relation(fields: [merchantId], references: [id])

  @@map("vendor_codes")
}

model Transaction {
  id                    String              @id @default(uuid()) @db.Uuid
  transactionRef        String              @unique @map("transaction_ref") @db.VarChar(40)
  type                  TransactionType
  status                TransactionStatus
  amount                BigInt
  currency              String              @default("INR") @db.Char(3)
  initiatedByUserId     String?             @map("initiated_by_user_id") @db.Uuid
  merchantId            String?             @map("merchant_id") @db.Uuid
  sourceWalletId        String?             @map("source_wallet_id") @db.Uuid
  destinationWalletId   String?             @map("destination_wallet_id") @db.Uuid
  idempotencyKeyId      String?             @map("idempotency_key_id") @db.Uuid
  failureCode           String?             @map("failure_code") @db.VarChar(80)
  failureMessage        String?             @map("failure_message") @db.Text
  metadata              Json                @default("{}")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt           DateTime?           @map("completed_at") @db.Timestamptz(6)
  initiatedByUser       User?               @relation(fields: [initiatedByUserId], references: [id])
  merchant              Merchant?           @relation(fields: [merchantId], references: [id])
  sourceWallet          Wallet?             @relation("SourceWallet", fields: [sourceWalletId], references: [id])
  destinationWallet     Wallet?             @relation("DestinationWallet", fields: [destinationWalletId], references: [id])
  idempotencyKey        IdempotencyKey?      @relation(fields: [idempotencyKeyId], references: [id])
  ledgerEntries         LedgerEntry[]
  gatewayLogs           PaymentGatewayLog[]
  webhookEvents         WebhookEvent[]
  transactionEvents     TransactionEvent[]
  originalReversals     Reversal[]          @relation("OriginalTransaction")
  reversalTransactions  Reversal[]          @relation("ReversalTransaction")

  @@index([initiatedByUserId, createdAt])
  @@index([merchantId, createdAt])
  @@index([status, createdAt])
  @@index([type, status, createdAt])
  @@map("transactions")
}

model LedgerEntry {
  id            String          @id @default(uuid()) @db.Uuid
  transactionId String          @map("transaction_id") @db.Uuid
  walletId      String          @map("wallet_id") @db.Uuid
  entryType     LedgerEntryType @map("entry_type")
  amount        BigInt
  currency      String          @default("INR") @db.Char(3)
  balanceAfter  BigInt          @map("balance_after")
  description   String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  transaction   Transaction     @relation(fields: [transactionId], references: [id])
  wallet        Wallet          @relation(fields: [walletId], references: [id])

  @@index([transactionId])
  @@index([walletId, createdAt])
  @@map("ledger_entries")
}

model IdempotencyKey {
  id           String             @id @default(uuid()) @db.Uuid
  actorType    ActorType          @map("actor_type")
  actorId      String             @map("actor_id") @db.Uuid
  scope        String             @db.VarChar(120)
  key          String             @db.VarChar(120)
  requestHash  String             @map("request_hash") @db.VarChar(128)
  status       IdempotencyStatus
  responseCode Int?               @map("response_code")
  responseBody Json?              @map("response_body")
  lockedUntil  DateTime?          @map("locked_until") @db.Timestamptz(6)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  transactions Transaction[]

  @@unique([actorType, actorId, scope, key])
  @@map("idempotency_keys")
}

model PaymentGatewayLog {
  id                String           @id @default(uuid()) @db.Uuid
  transactionId     String           @map("transaction_id") @db.Uuid
  provider          String           @db.VarChar(40)
  providerOrderId   String?          @map("provider_order_id") @db.VarChar(120)
  providerPaymentId String?          @map("provider_payment_id") @db.VarChar(120)
  flow              GatewayFlow
  direction         GatewayDirection
  status            String?          @db.VarChar(80)
  payload           Json
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  transaction       Transaction      @relation(fields: [transactionId], references: [id])

  @@index([provider, providerPaymentId])
  @@index([transactionId, createdAt])
  @@map("payment_gateway_logs")
}

model WebhookEvent {
  id             String        @id @default(uuid()) @db.Uuid
  provider       String        @db.VarChar(40)
  eventId        String        @map("event_id") @db.VarChar(160)
  eventType      String        @map("event_type") @db.VarChar(120)
  signatureValid Boolean       @map("signature_valid")
  transactionId  String?       @map("transaction_id") @db.Uuid
  payload        Json
  receivedAt     DateTime      @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt    DateTime?     @map("processed_at") @db.Timestamptz(6)
  status         WebhookStatus
  transaction    Transaction?  @relation(fields: [transactionId], references: [id])

  @@unique([provider, eventId])
  @@map("webhook_events")
}

model TransactionEvent {
  id            String      @id @default(uuid()) @db.Uuid
  transactionId String      @map("transaction_id") @db.Uuid
  eventType     String      @map("event_type") @db.VarChar(120)
  fromStatus    String?     @map("from_status") @db.VarChar(40)
  toStatus      String?     @map("to_status") @db.VarChar(40)
  metadata      Json        @default("{}")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("transaction_events")
}

model Reversal {
  id                    String      @id @default(uuid()) @db.Uuid
  originalTransactionId  String      @map("original_transaction_id") @db.Uuid
  reversalTransactionId  String      @map("reversal_transaction_id") @db.Uuid
  reason                String      @db.VarChar(120)
  createdByUserId       String?     @map("created_by_user_id") @db.Uuid
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  originalTransaction   Transaction @relation("OriginalTransaction", fields: [originalTransactionId], references: [id])
  reversalTransaction   Transaction @relation("ReversalTransaction", fields: [reversalTransactionId], references: [id])

  @@map("reversals")
}

model SettlementRecord {
  id         String           @id @default(uuid()) @db.Uuid
  merchantId String           @map("merchant_id") @db.Uuid
  amount     BigInt
  currency   String           @default("INR") @db.Char(3)
  status     SettlementStatus
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant   Merchant         @relation(fields: [merchantId], references: [id])

  @@map("settlement_records")
}

model AuditLog {
  id            String    @id @default(uuid()) @db.Uuid
  actorType     ActorType @map("actor_type")
  actorId       String?   @map("actor_id") @db.Uuid
  action        String    @db.VarChar(120)
  entityType    String?   @map("entity_type") @db.VarChar(80)
  entityId      String?   @map("entity_id") @db.Uuid
  ipAddress     String?   @map("ip_address") @db.Inet
  userAgent     String?   @map("user_agent") @db.Text
  correlationId String?   @map("correlation_id") @db.VarChar(80)
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorType, actorId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("audit_logs")
}
